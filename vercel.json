{
  "version": 2,
  "public": true,
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/dist/index.html"
    }
  ]
}
