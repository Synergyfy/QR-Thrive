// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String
  lastName      String
  password      String
  role          Role           @default(USER)
  plan          PlanType       @default(FREE)
  isBanned      Boolean        @default(false)
  
  // Paystack Integration
  paystackCustomerCode     String?   @unique
  paystackSubscriptionCode String?   @unique
  subscriptionStatus       String?   // e.g., "active", "non-renewing", "attention", "cancelled"
  billingCycle             String?   // "monthly", "quarterly", "yearly"

  refreshTokens RefreshToken[]
  folders       Folder[]
  qrCodes       QRCode[]
  deletedAt     DateTime?      // Added for Soft-Delete
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum PlanType {
  FREE
  PRO
}

model SystemConfig {
  id              Int      @id @default(1)
  
  // Pricing
  monthlyPrice    Float    @default(5000)
  quarterlyPrice  Float    @default(13500)
  yearlyPrice     Float    @default(50000)
  
  // Paystack Plan Codes (Sync'd with Paystack)
  monthlyPlanCode   String?
  quarterlyPlanCode String?
  yearlyPlanCode    String?
  
  // Content
  heroTitle       String   @default("Turn Every Scan Into a Customer")
  heroSubtitle    String   @default("Qrthrive helps you create powerful, branded QR codes.")
  features        Json     // Array of strings
  faqs            Json     // Array of {question, answer}
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  color     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodes   QRCode[]
  deletedAt DateTime? // Added for Soft-Delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum QRType {
  url
  text
  vcard
  wifi
  email
  sms
  whatsapp
  phone
  instagram
  facebook
  linkedin
  twitter
  youtube
  tiktok
  crypto
  socials
  links
  image
  event
  pdf
  video
  mp3
  app
  business
  menu
  coupon
  form
}

enum QRStatus {
  active
  archived
}

enum FormFieldType {
  text
  number
  range
  checkbox
  select
  radio
  email
  phone
}

model QRCode {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  folderId     String?
  folder       Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  
  name         String
  description  String?
  status       QRStatus  @default(active)
  
  shortId      String    @unique
  type         QRType
  isDynamic    Boolean   @default(true)
  
  data         Json
  design       Json
  frame        Json
  
  logo         String?
  width        Int       @default(400)
  height       Int       @default(400)
  margin       Int       @default(20)
  
  clicks       Int       @default(0)
  
  deletedAt    DateTime? // Added for Soft-Delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scans        Scan[]
  form         Form?

  @@index([userId])
}

model Scan {
  id         String   @id @default(cuid())
  qrCodeId   String
  qrCode     QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  
  ip         String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  city       String?
  country    String?
  region     String?
  
  createdAt  DateTime @default(now())

  @@index([qrCodeId])
  @@index([createdAt])
}

model Form {
  id          String      @id @default(cuid())
  qrCodeId    String      @unique
  qrCode      QRCode      @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  fields      FormField[]
  submissions FormSubmission[]
  
  deletedAt   DateTime?   // Added for Soft-Delete
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([qrCodeId])
}

model FormField {
  id          String        @id @default(cuid())
  formId      String
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  type        FormFieldType
  label       String
  placeholder String?
  helpText    String?
  required    Boolean       @default(false)
  
  options     Json?         // Array of options for select/radio: { label: string, value: string }[]
  validation  Json?         // Custom validation: { min?: number, max?: number, pattern?: string }
  order       Int           @default(0)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([formId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  answers   Json     // Map of fieldId to value
  
  ip        String?
  userAgent String?
  
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}
