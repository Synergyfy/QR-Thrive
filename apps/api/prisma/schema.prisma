// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  firstName     String
  lastName      String
  password      String?
  role          Role           @default(USER)
  
  // Dynamic Plan association
  planId        String?    @db.Uuid
  plan          Plan?          @relation(fields: [planId], references: [id])
  
  isBanned      Boolean        @default(false)
  googleId      String?        @unique
  avatar        String?
  
  // Paystack Integration
  paystackCustomerCode     String?   @unique
  paystackSubscriptionCode String?   @unique
  subscriptionStatus       String?   // e.g., "active", "non-renewing", "attention", "cancelled", "trialing"
  billingCycle             String?   // "monthly", "quarterly", "yearly"

  // Trial System
  trialStartedAt           DateTime?
  trialEndsAt              DateTime?
  hasUsedTrial             Boolean   @default(false)

  refreshTokens RefreshToken[]
  folders       Folder[]
  qrCodes       QRCode[]
  magicLinks    MagicLink[]    // Added for SSO
  pushSubscriptions PushSubscription[]
  supportTickets SupportTicket[] // Added for Support Chat
  scanNotificationsEnabled Boolean    @default(false)
  countryCode   String?        // ISO-2 country code for account locking
  deletedAt     DateTime?      // Added for Soft-Delete
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

model MagicLink {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model SystemConfig {
  id              Int      @id @default(1)
  
  // Pricing Discounts (Percentage)
  quarterlyDiscount Float    @default(10)
  yearlyDiscount    Float    @default(20)
  
  // Content
  heroTitle       String   @default("Turn Every Scan Into a Customer")
  heroSubtitle    String   @default("Qrthrive helps you create powerful, branded QR codes.")
  features        Json     // Array of strings
  faqs            Json     // Array of {question, answer}
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PricingTier {
  HIGH
  MIDDLE
  LOW
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum PriceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Country {
  code           String      @id // ISO 3166-1 alpha-2 (e.g., "US", "NG")
  name           String
  currencyCode   String      @default("USD")
  currencySymbol String      @default("$")
  tier           PricingTier @default(HIGH)
  taxRate        Float       @default(0.0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Plan {
  id            String      @id @default(uuid()) @db.Uuid
  name          String      @unique
  description   String?
  qrCodeLimit   Int         @default(10)
  qrCodeTypes   QRType[]    // PostgreSQL supporting enum arrays
  isPopular     Boolean     @default(false)
  isDefault     Boolean     @default(false)
  isFree        Boolean     @default(false)
  trialDays     Int         @default(0)
  isActive      Boolean     @default(true)
  
  vemtapPlanId          String? // Attached Vemtap Plan ID for bundling
  
  priceBooks    PriceBook[]
  users         User[]
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PriceBook {
  id            String       @id @default(uuid()) @db.Uuid
  
  planId        String       @db.Uuid
  plan          Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  tier          PricingTier
  currencyCode  String       // e.g., "NGN", "USD", "EUR"
  
  billingCycle  BillingCycle @default(MONTHLY)
  price         Float        // Numerical amount
  
  status        PriceStatus  @default(DRAFT)

  // Gateway Mapping
  stripePriceId    String?   // Stripe API Price ID
  paystackPlanCode String?   // Paystack API Plan Code (for recurring)

  activeFrom    DateTime?    

  activeTo      DateTime?    
    
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([planId, tier, currencyCode, billingCycle, status])
  @@index([planId, tier, currencyCode, billingCycle, status])
  @@map("price_books")
}

model Folder {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  color     String
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodes   QRCode[]
  deletedAt DateTime? // Added for Soft-Delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum QRType {
  url
  text
  vcard
  wifi
  email
  sms
  whatsapp
  phone
  instagram
  facebook
  linkedin
  twitter
  youtube
  tiktok
  crypto
  socials
  links
  image
  event
  pdf
  video
  mp3
  app
  business
  menu
  coupon
  form
}

enum QRStatus {
  active
  archived
}

enum FormFieldType {
  text
  number
  range
  checkbox
  select
  radio
  email
  phone
}

model QRCode {
  id           String    @id @default(uuid()) @db.Uuid
userId    String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  folderId     String?   @db.Uuid
  folder       Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  
  name         String
  description  String?
  status       QRStatus  @default(active)
  
  shortId      String    @unique
  type         QRType
  isDynamic    Boolean   @default(true)
  
  data         Json
  design       Json
  frame        Json
  
  logo         String?
  width        Int       @default(400)
  height       Int       @default(400)
  margin       Int       @default(20)
  
  clicks       Int       @default(0)
  
  deletedAt    DateTime? // Added for Soft-Delete
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scans        Scan[]
  form         Form?

  linkedQRCodeId String?   @db.Uuid
  linkedQRCode   QRCode?   @relation("QRLinks", fields: [linkedQRCodeId], references: [id], onDelete: SetNull)
  linkingQRCodes QRCode[]  @relation("QRLinks")

  @@index([userId])
}

model Scan {
  id         String   @id @default(uuid()) @db.Uuid
  qrCodeId   String   @db.Uuid
  qrCode     QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  
  ip         String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  city       String?
  country    String?
  region     String?
  
  createdAt  DateTime @default(now())

  @@index([qrCodeId])
  @@index([createdAt])
}

model Form {
  id          String      @id @default(uuid()) @db.Uuid
  qrCodeId    String      @unique @db.Uuid
  qrCode      QRCode      @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  fields      FormField[]
  submissions FormSubmission[]
  
  deletedAt   DateTime?   // Added for Soft-Delete
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([qrCodeId])
}

model FormField {
  id          String        @id @default(uuid()) @db.Uuid
  formId      String        @db.Uuid
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  type        FormFieldType
  label       String
  placeholder String?
  helpText    String?
  required    Boolean       @default(false)
  
  options     Json?         // Array of options for select/radio: { label: string, value: string }[]
  validation  Json?         // Custom validation: { min?: number, max?: number, pattern?: string }
  order       Int           @default(0)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([formId])
}

model FormSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  formId    String   @db.Uuid
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  answers   Json     // Map of fieldId to value
  
  ip        String?
  userAgent String?
  
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}

model ApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  key       String   @unique // Hashed key
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MessageSender {
  USER
  ADMIN
}

model SupportTicket {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @db.Uuid
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Guest support (unauthenticated FloatingChat lead form)
  guestName   String?
  guestEmail  String?

  subject     String        @default("Support Request")
  status      TicketStatus  @default(OPEN)

  messages       SupportMessage[]
  typingIndicators TypingIndicator[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @db.Uuid
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  sender    MessageSender
  text      String

  // Read receipt: set when the OTHER party first fetches this message
  readAt    DateTime?

  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_messages")
}

// Ephemeral typing indicator — auto-invalidated by updatedAt TTL, no cron needed
model TypingIndicator {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @db.Uuid
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  sender    MessageSender // who is typing
  updatedAt DateTime      @updatedAt // refresh this to "keep alive"

  @@unique([ticketId, sender]) // one row per (ticket, side)
  @@index([ticketId])
  @@map("typing_indicators")
}
